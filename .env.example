# Environment variables read by infer.py. Copy/adapt as needed.
# On the Pod, either `export` these manually or:  export $(grep -v '^#' .env.example | xargs)

# --- Input (set exactly one of these) ---------------------------------------
# Comma-separated list. Entries may be direct objects or prefixes (ending in "/",
# which are listed and filtered for .mp4). Prefix listing is single-page (<=1000).
S3_INPUT=s3://my-bucket/incoming-videos/
# Local folder of .mp4 files — for smoke-testing without S3 (mutually exclusive
# with S3_INPUT; if both set, S3_INPUT wins). Use "." to pick up sample_video.mp4.
# LOCAL_VIDEO_DIR=.

# --- Output & model ---------------------------------------------------------
OUTPUT_DIR=/workspace/output
MODEL_PATH=models/best.pt

# --- Inference tuning -------------------------------------------------------
CONF_THRESHOLD=0.4
IMG_SIZE=640
HEAVY_TRAFFIC_THRESHOLD=10
SAVE_ANNOTATED_VIDEO=true
PREVIEW_FRAME_FRACTION=0.5      # which frame to grab as the preview (0.0-1.0)
# MAX_SECONDS=30                # optional: only process the first N seconds of each
                                 # video. Unset = process the whole file (fine for short
                                 # clips; for multi-hour raw recordings, set this to avoid
                                 # very long runs — mirrors the team's render.sh --seconds).

# --- Runtime behavior -------------------------------------------------------
ENABLE_GUI=false               # true only makes sense with a real display (local dev)
ALLOW_CPU=false                # true = run on CPU if no GPU (slow); false = fail hard

# --- AWS credentials (omit all three if the Pod has an attached IAM role) ----
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
